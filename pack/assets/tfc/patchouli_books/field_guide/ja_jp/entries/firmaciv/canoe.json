          "0": "tfc:wood/stripped_log/douglas_fir[axis=x]",
          "B": "tfc:wood/stripped_log/douglas_fir[axis=x]"
        }
      },
      "name": "ただの原木",
      "text": "丸木舟を作る最初のステップ。",
